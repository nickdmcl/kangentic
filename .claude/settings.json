{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/bash-guard.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(touch:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(sort:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(tasklist:*)",
      "Bash(grep:*)",
      "Bash(du:*)",
      "Bash(powershell:*)",
      "Bash(powershell.exe:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(gh workflow:*)",
      "Bash(gh release:*)",
      "Bash(start:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__kangentic__kangentic_create_task",
      "mcp__kangentic__kangentic_list_columns",
      "mcp__kangentic__kangentic_list_tasks",
      "mcp__kangentic__kangentic_search_tasks",
      "mcp__kangentic__kangentic_find_task",
      "mcp__kangentic__kangentic_get_task_stats",
      "mcp__kangentic__kangentic_board_summary",
      "mcp__kangentic__kangentic_get_session_history",
      "mcp__kangentic__kangentic_get_column_detail",
      "mcp__kangentic__kangentic_update_task",
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:www.electronjs.org)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.npmjs.org)",
      "Skill"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true
}
