{
  "name": "kangentic",
  "productName": "Kangentic",
  "version": "0.1.0",
  "description": "Cross-platform desktop Kanban for Claude Code agents",
  "bin": {
    "kgnt": "./bin/kgnt.js"
  },
  "main": ".vite/build/index.js",
  "repository": "https://github.com/Kangentic/kangentic",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "npx playwright test",
    "test:headed": "HEADED=1 npx playwright test",
    "test:screenshots": "npx playwright test --grep Screenshots",
    "test:unit": "vitest run",
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js"
  },
  "keywords": [],
  "author": {
    "name": "Kangentic",
    "url": "https://github.com/Kangentic"
  },
